generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas  = ["magic_story", "public"]
}

// ==========================================
// 核心项目模型
// ==========================================

model Project {
  id          String   @id @default(cuid())
  title       String
  genre       String   @default("玄幻系统修仙")
  description String   @default("")
  coverImage  String   @default("")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  worldSettings       WorldSetting[]
  characters          Character[]
  characterRelations  CharacterRelationship[]
  outlines            Outline[]
  chapters            Chapter[]
  promptTemplates     PromptTemplate[]
  agentLogs           AgentLog[]
  storyStates         StoryState[]
  foreshadowings      Foreshadowing[]
  storyNodes          StoryNode[]
  storyEdges          StoryEdge[]
  scenes              Scene[]
  plots               Plot[]
  assetLinks          ProjectAssetLink[]

  @@schema("magic_story")
}

// ==========================================
// 模块二：项目管理 - 五类资产
// ==========================================

/// 大纲资产
model Outline {
  id        String  @id @default(cuid())
  projectId String
  content   String  @default("")
  version   Int     @default(1)
  tags      String  @default("[]") // JSON array of tags
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

/// 角色资产（含AI生成图片）
model Character {
  id              String  @id @default(cuid())
  projectId       String
  name            String
  age             String  @default("")
  role            String  @default("主角")
  personality     String  @default("")
  appearance      String  @default("")
  background      String  @default("")
  arc             String  @default("")
  portraitUrl     String  @default("")  // AI生成的角色图片URL (base64 or URL)
  portraitPrompt  String  @default("")  // 自定义风格提示词
  tags            String  @default("[]") // JSON array of tags
  isFavorite      Boolean @default(false)
  version         Int     @default(1)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fromRelations CharacterRelationship[] @relation("FromCharacter")
  toRelations   CharacterRelationship[] @relation("ToCharacter")

  @@schema("magic_story")
}

model CharacterRelationship {
  id              String  @id @default(cuid())
  projectId       String
  fromCharacterId String
  toCharacterId   String
  type            String  @default("盟友")
  description     String  @default("")

  project       Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromCharacter Character @relation("FromCharacter", fields: [fromCharacterId], references: [id], onDelete: Cascade)
  toCharacter   Character @relation("ToCharacter", fields: [toCharacterId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

/// 剧情资产
model Plot {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String   @default("")
  plotType    String   @default("main") // main | sub | task | dungeon | scene | event
  priority    Int      @default(0)
  status      String   @default("planned") // planned | active | completed | abandoned
  tags        String   @default("[]")
  order       Int      @default(0)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

/// 场景资产
model Scene {
  id          String   @id @default(cuid())
  projectId   String
  name        String
  description String   @default("")
  location    String   @default("")  // 场景地点
  atmosphere  String   @default("")  // 氛围描述
  timeOfDay   String   @default("")  // 时间段
  tags        String   @default("[]")
  order       Int      @default(0)
  version     Int      @default(1)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

/// 世界观资产
model WorldSetting {
  id          String  @id @default(cuid())
  projectId   String
  name        String
  description String  @default("")
  rules       String  @default("")
  type        String  @default("background")
  order       Int     @default(0)
  tags        String  @default("[]")
  version     Int     @default(1)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

/// 跨项目资产链接（浅拷贝引用）
model ProjectAssetLink {
  id           String   @id @default(cuid())
  projectId    String
  assetType    String   // outline | character | plot | scene | world
  sourceAssetId String  // 原资产ID
  sourceProjectId String // 原项目ID
  createdAt    DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

// ==========================================
// 模块一：创作中心 - 章节与对话
// ==========================================

model Chapter {
  id             String  @id @default(cuid())
  projectId      String
  order          Int
  title          String  @default("")
  outlineContent String  @default("")
  content        String  @default("")
  summary        String  @default("")
  wordCount      Int     @default(0)
  status         String  @default("draft")
  emotionTarget  String  @default("")
  emotionArc     String  @default("")
  hookStart      String  @default("")
  hookEnd        String  @default("")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  storyStates StoryState[]
  foreshadowings Foreshadowing[]

  @@schema("magic_story")
}

model StoryState {
  id        String   @id @default(cuid())
  projectId String
  chapterId String
  type      String   @default("character_state")
  data      String   @default("{}")
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

model Foreshadowing {
  id                String  @id @default(cuid())
  projectId         String
  chapterId         String
  content           String  @default("")
  expectedResolveChapter Int @default(0)
  status            String  @default("planted")
  importance        String  @default("medium")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  chapter Chapter @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

// ==========================================
// 模块三：全景图谱 - 叙事地图
// ==========================================

/// 故事节点
model StoryNode {
  id          String   @id @default(cuid())
  projectId   String
  nodeType    String   @default("main") // main | sub | task | dungeon | scene | event
  title       String
  description String   @default("")
  positionX   Float    @default(0)
  positionY   Float    @default(0)
  metadata    String   @default("{}") // JSON: 关联角色ID、场景ID、伏笔等
  color       String   @default("")   // 自定义颜色
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceEdges StoryEdge[] @relation("SourceNode")
  targetEdges StoryEdge[] @relation("TargetNode")

  @@schema("magic_story")
}

/// 故事连线
model StoryEdge {
  id          String   @id @default(cuid())
  projectId   String
  sourceId    String
  targetId    String
  label       String   @default("")
  edgeType    String   @default("causal") // causal | temporal | character | foreshadow
  metadata    String   @default("{}")
  createdAt   DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceNode StoryNode @relation("SourceNode", fields: [sourceId], references: [id], onDelete: Cascade)
  targetNode StoryNode @relation("TargetNode", fields: [targetId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

// ==========================================
// 共享模型
// ==========================================

model PromptTemplate {
  id        String  @id @default(cuid())
  projectId String
  name      String
  type      String  @default("general")
  content   String
  isDefault Boolean @default(false)

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}

model AgentLog {
  id        String   @id @default(cuid())
  projectId String
  agentType String
  action    String
  input     String   @default("")
  output    String   @default("")
  toolCalls String   @default("[]") // JSON: 工具调用记录
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@schema("magic_story")
}
